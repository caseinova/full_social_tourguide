import rclpy
from rclpy.node import Node
# audio_common_msgs or standard Byte arrays are typically sent via UInt8MultiArray
from std_msgs.msg import UInt8MultiArray 
import numpy as np

class RealTimeAudioProcessor(Node):

    def __init__(self):
        super().__init__('realtime_audio_processor_node')
        
        # Subscribe to the incoming stream coming from Pepper
        self.subscription = self.create_subscription(
            UInt8MultiArray,
            '/audio/audio',
            self.audio_callback,
            10)
        
        self.get_logger().info("Real-Time Audio Processing Node started on Laptop.")

    def audio_callback(self, msg):
        # 1. Convert raw message bytes directly into a usable data array
        raw_data = np.array(msg.data, dtype=np.uint8)
        
        if len(raw_data) == 0:
            return

        # 2. Convert 8-bit unsigned data to 16-bit PCM Linear format if Pepper is streaming raw audio
        # (Depending on Pepper's capture settings, you may change this format)
        audio_samples = (raw_data.astype(np.int16) - 128) * 256
        
        # 3. Calculate current volume/amplitude to prove real-time tracking works
        amplitude = np.max(np.abs(audio_samples))
        
        # ====================================================================
        # PLACEHOLDER FOR REAL-TIME PROCESSING:
        # This is where you can pipe 'audio_samples' straight into Speech-To-Text 
        # (like Whisper or Vosk) or Keyword Spotting algorithms.
        # ====================================================================
        
        if amplitude > 2000: # Simple threshold log to see if Pepper hears something
            self.get_logger().info(f"[AUDIO] Real-time noise detected! Amplitude: {amplitude}")

def main(args=None):
    rclpy.init(args=args)
    node = RealTimeAudioProcessor()
    
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()

if __name__ == '__main__':
    main()